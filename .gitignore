# ══════════════════════════════════════════════════════════════════════
# .gitignore — Plateforme Sentiment E-commerce Maroc
# ══════════════════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────────────────
__pycache__/
*.py[codz]
*$py.class
*.so
*.egg-info/
*.egg
MANIFEST
.installed.cfg
dist/
build/
develop-eggs/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/

# ── Environnements virtuels ───────────────────────────────────────────
.env
.envrc
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.pixi
.pdm-python
.pdm-build/
__pypackages__/

# ── Tests / Couverture ────────────────────────────────────────────────
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/

# ── Notebooks ─────────────────────────────────────────────────────────
.ipynb_checkpoints

# ── IPython / Jupyter ─────────────────────────────────────────────────
profile_default/
ipython_config.py

# ── Type checkers ────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
cython_debug/
.ruff_cache/

# ── Django / Flask / Scrapy ──────────────────────────────────────────
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
instance/
.webassets-cache
.scrapy

# ── Build / Packaging ────────────────────────────────────────────────
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt
*.mo
*.pot

# ── Outils ───────────────────────────────────────────────────────────
.abstra/
.cursorignore
.cursorindexingignore
.pypirc
marimo/_static/
marimo/_lsp/
__marimo__/
/site

# ── Éditeurs ─────────────────────────────────────────────────────────
# .vscode/          # décommentez si vous ne partagez pas vos settings VS Code
# .idea/            # décommentez si vous ne partagez pas vos settings JetBrains

# ══════════════════════════════════════════════════════════════════════
# DATA — Règles précises (PAS de *.csv global qui efface tout)
# ══════════════════════════════════════════════════════════════════════

# Données brutes Flipkart téléchargeables séparément (trop grosses pour Git)
data/flipkart_data.csv

# Fichiers CSV générés à l'exécution (exports scraping, résultats de tests)
data/scraping_*.csv
data/resultats_*.csv
data/export_*.csv

# ⚠️  NE PAS ignorer — données essentielles versionnées :
# data/flipkart_data_preprocessed.csv
# data/flipkart_data_with_sentiment.csv
# data/y_train.csv
# data/y_test.csv

# ══════════════════════════════════════════════════════════════════════
# MODÈLES — Les .pkl sont versionnés (petits, reproductibilité soutenance)
# ══════════════════════════════════════════════════════════════════════
# Pour exclure les .pkl si trop volumineux, décommentez :
# models/*.pkl

# Cache HuggingFace (téléchargements automatiques, souvent plusieurs Go)
~/.cache/huggingface/
.cache/huggingface/

# ══════════════════════════════════════════════════════════════════════
# PLAYWRIGHT / BROWSERS
# ══════════════════════════════════════════════════════════════════════
# Navigateurs Playwright (installés localement, non committés)
# ~/.cache/ms-playwright/

# ══════════════════════════════════════════════════════════════════════
# DIVERS
# ══════════════════════════════════════════════════════════════════════
# Locks (à décommenter selon votre workflow)
# Pipfile.lock
# poetry.lock
# uv.lock
# pixi.lock